# Supabase (gridon 프로젝트) — 공개(NEXT_PUBLIC) 값. 빌드 시 정적 번들에 인라인됨.
# 로컬 개발: 이 파일을 .env.local 로 복사한 뒤 실제 값으로 채우세요.
# CI(Cloudflare Pages 배포): GitHub repo Settings → Secrets 에 동일 이름으로 등록.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-OR-PUBLISHABLE-KEY
