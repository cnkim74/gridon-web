# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
# 공개 NEXT_PUBLIC 값만 담긴 프로덕션 env — CI 빌드에서 사용하므로 추적한다.
!.env.production

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# macOS AppleDouble files (exFAT volume)
._*
.DS_Store
